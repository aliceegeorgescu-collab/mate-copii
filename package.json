{
  "name": "mate-copii-platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend start",
    "dev:backend": "npm --workspace backend run dev",
